# Stellar / Soroban
NEXT_PUBLIC_CONTRACT_ID=
NEXT_PUBLIC_NETWORK=testnet
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_SOROBAN_RPC=https://soroban-testnet.stellar.org

# IPFS / Pinata
PINATA_API_KEY=
PINATA_SECRET=
NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs

# Backend API
NEXT_PUBLIC_API_URL=http://localhost:4000

# Auth (SEP-10)
STELLAR_SECRET_KEY=
NEXT_PUBLIC_DOMAIN=localhost:3000

# Error monitoring (optional — leave blank to disable Sentry)
NEXT_PUBLIC_SENTRY_DSN=

# Platform config
PLATFORM_CONTACT_FEE_XLM=1
NEXT_PUBLIC_ADMIN_ADDRESS=

# PWA / App URL (used for manifest start_url, OG tags, and sitemap generation)
NEXT_PUBLIC_APP_URL=https://scoutoff.app

# Runtime (set automatically by Next.js)
NODE_ENV=
