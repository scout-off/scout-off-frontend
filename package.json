{
  "name": "scout-off-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest --passWithNoTests --maxWorkers=2 --workerIdleMemoryLimit=512MB",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md,mdx}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md,mdx}\"",
    "prepare": "node -e \"if (process.env.CI !== 'true') { require('child_process').execSync('husky install', {stdio: 'inherit'}) }\"",
    "postbuild": "next-sitemap",
    "generate:icons": "node scripts/generate-icons.js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@albedo-link/intent": "^0.13.0",
    "@lobstrco/signer-extension-api": "2.0.0",
    "@sentry/nextjs": "^10.59.0",
    "@stellar/freighter-api": "2.0.0",
    "@stellar/stellar-sdk": "12.1.0",
    "@vercel/analytics": "^2.0.0",
    "axios": "1.7.2",
    "dompurify": "^3.4.11",
    "lucide-react": "^1.17.0",
    "next": "14.2.3",
    "next-intl": "^4.13.0",
    "next-pwa": "5.6.0",
    "postcss": "^8.5.15",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "swr": "^2.4.1",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@axe-core/react": "4.9.1",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/builder-vite": "^10.4.6",
    "@storybook/nextjs": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "6.4.6",
    "@testing-library/react": "16.0.0",
    "@testing-library/user-event": "14.4.3",
    "@types/dompurify": "^3.0.5",
    "@types/jest": "29.5.5",
    "@types/minimatch": "^5.1.2",
    "@types/node": "20.14.2",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.19",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.3",
    "husky": "9.1.7",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "lint-staged": "^14.0.0",
    "next-sitemap": "4.2.3",
    "prettier": "^3.8.1",
    "storybook": "^8.6.18",
    "vite": "^8.1.0",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,mdx}": [
      "prettier --write"
    ]
  }
}
